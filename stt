#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.10"
# dependencies = [
#   "dashscope>=1.20.0",
#   "httpx>=0.27.0",
# ]
# ///
"""全局 STT：阿里云 DashScope Fun-ASR 音频转字幕。

从 fof-clerk 的 clerk.stt.asr 抽取的独立 CLI，不依赖项目配置与 OSS。

环境变量:
    ALIYUN_ASR_API_KEY  阿里云百炼 / DashScope API Key（必填）

用法:
    stt meeting.m4a
    stt meeting.mp3 -o meeting.srt
    stt https://example.com/a.wav --format txt
    stt audio.wav --lang zh --lang en --diarization
    stt audio.wav --format json -o result.json
"""

from __future__ import annotations

import argparse
import json
import os
import sys
import time
from dataclasses import dataclass
from pathlib import Path
from typing import Any, Callable
from urllib.parse import urlparse

# ---------------------------------------------------------------------------
# constants
# ---------------------------------------------------------------------------

API_BASE = "https://dashscope.aliyuncs.com/api/v1"
SUBMIT_URL = f"{API_BASE}/services/audio/asr/transcription"
TASK_URL = f"{API_BASE}/tasks/{{task_id}}"

TERMINAL_STATUSES = frozenset({"SUCCEEDED", "FAILED", "CANCELED", "UNKNOWN"})
STATUS_DETAIL = {
    "PENDING": "排队中",
    "RUNNING": "语音转写中",
    "SUSPENDED": "已挂起",
    "SUCCEEDED": "转写完成",
    "FAILED": "转写失败",
    "CANCELED": "已取消",
    "UNKNOWN": "状态未知",
}

AUDIO_EXTS = {".mp3", ".wav", ".m4a", ".aac", ".flac", ".ogg", ".wma", ".amr", ".webm", ".mp4"}


# ---------------------------------------------------------------------------
# data
# ---------------------------------------------------------------------------


@dataclass
class Segment:
    text: str
    start_ms: int
    end_ms: int
    speaker_id: int | None = None

    def to_dict(self) -> dict[str, Any]:
        d: dict[str, Any] = {
            "text": self.text,
            "start_ms": self.start_ms,
            "end_ms": self.end_ms,
        }
        if self.speaker_id is not None:
            d["speaker_id"] = self.speaker_id
        return d


# ---------------------------------------------------------------------------
# API key / source resolve
# ---------------------------------------------------------------------------


def require_api_key() -> str:
    key = os.environ.get("ALIYUN_ASR_API_KEY", "").strip()
    if not key:
        print(
            "Error: 未设置环境变量 ALIYUN_ASR_API_KEY（阿里云百炼 API Key）",
            file=sys.stderr,
        )
        sys.exit(1)
    return key


def is_http_url(s: str) -> bool:
    return s.startswith("http://") or s.startswith("https://")


def resolve_file_url(source: str, *, model: str, api_key: str) -> tuple[str, bool]:
    """返回 (file_url, needs_oss_resolve)。

    公网 http(s) URL 直接返回；本地文件经 DashScope 临时 OSS 上传，
    得到 oss:// 临时地址（调用 REST 时需 X-DashScope-OssResourceResolve）。
    """
    if is_http_url(source):
        return source, False

    path = Path(source).expanduser().resolve()
    if not path.is_file():
        print(f"Error: 文件不存在: {source}", file=sys.stderr)
        sys.exit(1)

    from dashscope.utils.oss_utils import OssUtils

    print(f"上传本地文件到临时存储: {path.name} ...", file=sys.stderr)
    file_url, _cert = OssUtils.upload(
        model=model,
        file_path=str(path),
        api_key=api_key,
    )
    if not file_url:
        print("Error: 本地文件上传失败", file=sys.stderr)
        sys.exit(1)
    print(f"上传完成: {file_url}", file=sys.stderr)
    return file_url, True


# ---------------------------------------------------------------------------
# transcription (REST — supports oss:// with resolve header)
# ---------------------------------------------------------------------------


def _headers(api_key: str, *, oss_resolve: bool = False) -> dict[str, str]:
    h = {
        "Authorization": f"Bearer {api_key}",
        "Content-Type": "application/json",
        "X-DashScope-Async": "enable",
    }
    if oss_resolve:
        h["X-DashScope-OssResourceResolve"] = "enable"
    return h


def submit_task(
    *,
    api_key: str,
    file_url: str,
    model: str,
    language_hints: list[str] | None,
    diarization: bool,
    oss_resolve: bool,
) -> str:
    import httpx

    parameters: dict[str, Any] = {}
    if language_hints:
        parameters["language_hints"] = language_hints
    if diarization:
        parameters["diarization_enabled"] = True

    payload: dict[str, Any] = {
        "model": model,
        "input": {"file_urls": [file_url]},
    }
    if parameters:
        payload["parameters"] = parameters

    r = httpx.post(
        SUBMIT_URL,
        headers=_headers(api_key, oss_resolve=oss_resolve),
        json=payload,
        timeout=60.0,
    )
    if r.status_code >= 400:
        raise RuntimeError(f"提交 ASR 任务失败 HTTP {r.status_code}: {r.text}")

    data = r.json()
    output = data.get("output") or {}
    task_id = output.get("task_id")
    if not task_id:
        raise RuntimeError(f"提交 ASR 任务未返回 task_id: {data}")
    return task_id


def poll_until_done(
    *,
    api_key: str,
    task_id: str,
    on_status: Callable[[str, str], None] | None = None,
) -> dict[str, Any]:
    """轮询任务直到终态。backoff: 起始 1s，每 3 次 ×2，封顶 5s。"""
    import httpx

    wait_seconds = 1.0
    max_wait_seconds = 5.0
    increment_steps = 3
    step = 0

    while True:
        r = httpx.get(
            TASK_URL.format(task_id=task_id),
            headers=_headers(api_key),
            timeout=60.0,
        )
        if r.status_code >= 400:
            raise RuntimeError(f"查询 ASR 任务失败 HTTP {r.status_code}: {r.text}")

        data = r.json()
        output = data.get("output") or {}
        ts = output.get("task_status") or "UNKNOWN"
        detail = STATUS_DETAIL.get(ts, ts)
        if on_status is not None:
            on_status(ts, detail)

        if ts in TERMINAL_STATUSES:
            return data

        time.sleep(wait_seconds)
        step += 1
        if step % increment_steps == 0:
            wait_seconds = min(wait_seconds * 2, max_wait_seconds)


def extract_transcription_url(task_data: dict[str, Any]) -> str:
    """兼容官方扁平 results[] 与少数嵌套 results[].output.results[] 结构。"""
    out = task_data.get("output") or {}
    for top in out.get("results") or []:
        if not isinstance(top, dict):
            continue
        url = top.get("transcription_url")
        if url:
            return url
        # 嵌套：results[].output.results[].transcription_url
        inner_out = top.get("output") or {}
        for inner in inner_out.get("results") or []:
            if isinstance(inner, dict) and inner.get("transcription_url"):
                return inner["transcription_url"]
    return ""


def download_json(url: str) -> dict[str, Any]:
    import httpx

    r = httpx.get(url, timeout=60.0)
    r.raise_for_status()
    return r.json()


def parse_segments(raw: dict[str, Any]) -> list[Segment]:
    """从 Fun-ASR 结果 JSON 解析句级 segment。

    结构：{transcripts:[{sentences:[{text, begin_time, end_time, speaker_id?}, ...]}]}
    begin_time/end_time 单位毫秒。
    """
    segments: list[Segment] = []
    for tr in raw.get("transcripts") or []:
        for sent in tr.get("sentences") or []:
            text = (sent.get("text") or "").strip()
            if not text:
                continue
            speaker = sent.get("speaker_id")
            segments.append(
                Segment(
                    text=text,
                    start_ms=int(sent.get("begin_time", 0)),
                    end_ms=int(sent.get("end_time", 0)),
                    speaker_id=int(speaker) if speaker is not None else None,
                )
            )
    return segments


def transcribe(
    source: str,
    *,
    api_key: str,
    model: str = "fun-asr",
    language_hints: list[str] | None = None,
    diarization: bool = False,
) -> tuple[list[Segment], dict[str, Any], str]:
    """转录音频，返回 (segments, 原始结果 JSON, task_id)。"""
    file_url, oss_resolve = resolve_file_url(source, model=model, api_key=api_key)

    def _on_status(ts: str, detail: str) -> None:
        print(f"[{ts}] {detail}", file=sys.stderr)

    print("提交 ASR 任务...", file=sys.stderr)
    task_id = submit_task(
        api_key=api_key,
        file_url=file_url,
        model=model,
        language_hints=language_hints,
        diarization=diarization,
        oss_resolve=oss_resolve,
    )
    print(f"task_id={task_id}", file=sys.stderr)

    task_data = poll_until_done(api_key=api_key, task_id=task_id, on_status=_on_status)
    output = task_data.get("output") or {}
    ts = output.get("task_status")
    if ts != "SUCCEEDED":
        raise RuntimeError(
            f"Fun-ASR 任务未成功，task_id={task_id}, status={ts}, "
            f"body={json.dumps(task_data, ensure_ascii=False)[:500]}"
        )

    transcription_url = extract_transcription_url(task_data)
    if not transcription_url:
        raise RuntimeError(
            f"Fun-ASR 任务完成但未取到 transcription_url，task_id={task_id}"
        )

    raw_json = download_json(transcription_url)
    segments = parse_segments(raw_json)
    return segments, raw_json, task_id


# ---------------------------------------------------------------------------
# subtitle formatters
# ---------------------------------------------------------------------------


def ms_to_srt_time(ms: int) -> str:
    if ms < 0:
        ms = 0
    h, rem = divmod(ms, 3_600_000)
    m, rem = divmod(rem, 60_000)
    s, milli = divmod(rem, 1000)
    return f"{h:02d}:{m:02d}:{s:02d},{milli:03d}"


def ms_to_vtt_time(ms: int) -> str:
    if ms < 0:
        ms = 0
    h, rem = divmod(ms, 3_600_000)
    m, rem = divmod(rem, 60_000)
    s, milli = divmod(rem, 1000)
    return f"{h:02d}:{m:02d}:{s:02d}.{milli:03d}"


def format_srt(segments: list[Segment]) -> str:
    lines: list[str] = []
    for i, seg in enumerate(segments, 1):
        text = seg.text
        if seg.speaker_id is not None:
            text = f"[S{seg.speaker_id}] {text}"
        lines.append(str(i))
        lines.append(f"{ms_to_srt_time(seg.start_ms)} --> {ms_to_srt_time(seg.end_ms)}")
        lines.append(text)
        lines.append("")
    return "\n".join(lines)


def format_vtt(segments: list[Segment]) -> str:
    lines = ["WEBVTT", ""]
    for seg in segments:
        text = seg.text
        if seg.speaker_id is not None:
            text = f"<v S{seg.speaker_id}>{text}"
        lines.append(f"{ms_to_vtt_time(seg.start_ms)} --> {ms_to_vtt_time(seg.end_ms)}")
        lines.append(text)
        lines.append("")
    return "\n".join(lines)


def format_txt(segments: list[Segment]) -> str:
    lines: list[str] = []
    for seg in segments:
        if seg.speaker_id is not None:
            lines.append(f"[S{seg.speaker_id}] {seg.text}")
        else:
            lines.append(seg.text)
    return "\n".join(lines) + ("\n" if lines else "")


def format_json(segments: list[Segment], raw: dict[str, Any], task_id: str) -> str:
    payload = {
        "task_id": task_id,
        "segments": [s.to_dict() for s in segments],
        "raw": raw,
    }
    return json.dumps(payload, ensure_ascii=False, indent=2) + "\n"


def default_output_path(source: str, fmt: str) -> Path:
    if is_http_url(source):
        name = Path(urlparse(source).path).stem or "transcript"
        return Path.cwd() / f"{name}.{fmt}"
    return Path(source).expanduser().resolve().with_suffix(f".{fmt}")


# ---------------------------------------------------------------------------
# CLI
# ---------------------------------------------------------------------------


def build_parser() -> argparse.ArgumentParser:
    p = argparse.ArgumentParser(
        prog="stt",
        description="阿里云 Fun-ASR 音频转字幕（Key: ALIYUN_ASR_API_KEY）",
    )
    p.add_argument(
        "source",
        help="本地音频路径，或公网可访问的 http(s) URL",
    )
    p.add_argument(
        "-o",
        "--output",
        default=None,
        help="输出文件路径（默认：源文件同名改后缀，或当前目录 transcript.*）",
    )
    p.add_argument(
        "-f",
        "--format",
        choices=("srt", "vtt", "txt", "json"),
        default="srt",
        help="输出格式（默认 srt）",
    )
    p.add_argument(
        "--model",
        default="fun-asr",
        help="模型名（默认 fun-asr；多语可用 fun-asr-mtl）",
    )
    p.add_argument(
        "--lang",
        action="append",
        dest="langs",
        default=None,
        metavar="CODE",
        help="语言提示，可重复，如 --lang zh --lang en",
    )
    p.add_argument(
        "--diarization",
        action="store_true",
        help="启用说话人分离",
    )
    p.add_argument(
        "--stdout",
        action="store_true",
        help="结果打印到 stdout，不写文件",
    )
    return p


def main(argv: list[str] | None = None) -> int:
    args = build_parser().parse_args(argv)
    api_key = require_api_key()

    source = args.source
    if not is_http_url(source):
        ext = Path(source).suffix.lower()
        if ext and ext not in AUDIO_EXTS:
            print(
                f"Warning: 扩展名 {ext} 可能不受支持，继续尝试...",
                file=sys.stderr,
            )

    try:
        segments, raw_json, task_id = transcribe(
            source,
            api_key=api_key,
            model=args.model,
            language_hints=args.langs,
            diarization=args.diarization,
        )
    except Exception as e:
        print(f"Error: {e}", file=sys.stderr)
        return 1

    if not segments:
        print("Warning: 未解析到任何句级结果", file=sys.stderr)

    fmt = args.format
    if fmt == "srt":
        body = format_srt(segments)
    elif fmt == "vtt":
        body = format_vtt(segments)
    elif fmt == "txt":
        body = format_txt(segments)
    else:
        body = format_json(segments, raw_json, task_id)

    if args.stdout:
        sys.stdout.write(body)
        if body and not body.endswith("\n"):
            sys.stdout.write("\n")
    else:
        out = Path(args.output) if args.output else default_output_path(source, fmt)
        out = out.expanduser().resolve()
        out.parent.mkdir(parents=True, exist_ok=True)
        out.write_text(body, encoding="utf-8")
        print(f"已写入 {out}（{len(segments)} 句, task_id={task_id}）", file=sys.stderr)

    return 0


if __name__ == "__main__":
    raise SystemExit(main())
